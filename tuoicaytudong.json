    {
        "id": "3496e4aca7c9e0f3",
        "type": "function",
        "z": "0e78bdfeceb054f5",
        "name": "Kiểm tra & Cảnh báo Email",
        "func": "let tempValue = Number(msg.payload.temperature);\nlet humValue  = Number(msg.payload.humidity);\nlet soilValue = Number(msg.payload.soil_moisture); \n\nlet tempString = tempValue.toFixed(1);\nlet humString  = humValue.toFixed(1);\n\nlet lastSent = flow.get(\"lastSentMail\") || 0;\nlet now = Date.now();\n\nlet TEMP_HIGH = 35; // Ngưỡng nhiệt độ cao\nlet SOIL_LOW  = 30; // Ngưỡng đất khô\n\n// So sánh bằng giá trị số thực tế\nlet isTooHot = tempValue >= TEMP_HIGH;\nlet isTooDry = soilValue <= SOIL_LOW;\n\nif ((isTooHot || isTooDry) && (now - lastSent > 600000)) {\n    flow.set(\"lastSentMail\", now);\n    let alertReason = \"\";\n    \n    if (isTooHot && isTooDry) {\n        alertReason = \"Trời CỰC KỲ NÓNG và ĐẤT RẤT KHÔ!\";\n    } else if (isTooHot) {\n        alertReason = \"Nhiệt độ QUÁ CAO! Nguy cơ héo lá!\";\n    } else if (isTooDry) {\n        alertReason = \"Đất RẤT KHÔ! Vui lòng kiểm tra máy bơm!\";\n    }\n    \n    let newMsg = {};\n    newMsg.topic = \"🚨 CẢNH BÁO VƯỜN 🚨\";\n    newMsg.payload = `CẢNH BÁO HỆ THỐNG TƯỚI CÂY TỰ ĐỘNG!\\n\\n` +\n                     `Nguyên nhân: ${alertReason}\\n\\n` +\n                     `THÔNG SỐ HIỆN TẠI:\\n` +\n                     `- Nhiệt độ không khí: ${tempString}°C\\n` +\n                     `- Độ ẩm không khí: ${humString}%\\n` +\n                     `- Độ ẩm đất: ${soilValue}%\\n\\n` +\n                     `Ra vườn kiểm tra nhé!`;\n                     \n    return newMsg; \n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 40,
        "wires": [
            [
                "08eed087ca744b61"
            ]
        ]
    },
