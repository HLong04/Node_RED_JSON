    {
        "id": "7f0c96036c8fee2a",
        "type": "function",
        "z": "0e78bdfeceb054f5",
        "name": "Tách Dữ Liệu ",
        "func": "let msg_temp = { payload: msg.payload.temperature };\nlet msg_hum = { payload: msg.payload.humidity };\nlet msg_soil = { payload: msg.payload.soil_moisture };\n\nreturn [msg_temp, msg_hum, msg_soil];",
